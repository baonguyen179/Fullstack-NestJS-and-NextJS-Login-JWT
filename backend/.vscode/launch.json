{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Nest Framework",
      "args": ["start", "--debug", "--watch"],
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run"],
      "protocol": "inspector",
      "autoAttachChildProcesses": true,
      "restart": true,
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}